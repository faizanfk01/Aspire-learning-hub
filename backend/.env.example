# ── Email — Resend ────────────────────────────────────────────────────────────
RESEND_API_KEY=

# ── Public URLs ───────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
RESET_TOKEN_EXPIRE_MINUTES=30

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
