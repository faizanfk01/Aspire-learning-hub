# Database
DATABASE_URL=

# Auth / JWT
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Groq AI (tutor)
GROQ_API_KEY=
GROQ_API_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# Email — Resend
RESEND_API_KEY=
ADMIN_EMAIL=
CONTACT_EMAIL=

# Observability — DEBUG logs every request and SQL query, use INFO in production
LOG_LEVEL=INFO

# Public URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
RESET_TOKEN_EXPIRE_MINUTES=30

# CORS — comma-separated; in production set to your custom domain only
# Example: CORS_ORIGINS=https://www.aspirelearninghub.com.pk,https://aspirelearninghub.com.pk
CORS_ORIGINS=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Production: https://www.aspirelearninghub.com.pk/api/auth/callback/google
GOOGLE_REDIRECT_URI=
