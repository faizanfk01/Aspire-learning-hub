# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=

# ── Auth / JWT ────────────────────────────────────────────────────────────────
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Groq AI (tutor) ───────────────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_API_BASE_URL=https://api.groq.com/openai/v1
