# the committed docker-compose.yml
docker-compose.override.yml

# ─── IDE ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ─── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
