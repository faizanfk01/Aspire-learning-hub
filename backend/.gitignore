# ─── Secrets — NEVER commit these ────────────────────────────────────────────
.env
.env.*
!.env.example

# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
.Python

# ─── Packaging & distribution ─────────────────────────────────────────────────
*.egg
*.egg-info/
dist/
build/
wheels/
sdist/
MANIFEST

# ─── Virtual environments ─────────────────────────────────────────────────────
venv/
.venv/
env/
.env/
ENV/

# ─── Testing & coverage ───────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
nosetests.xml
coverage.xml
*.cover
test.db
*.db

# ─── Type checking ────────────────────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
.pyright/

# ─── Alembic ──────────────────────────────────────────────────────────────────
