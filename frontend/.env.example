# ── Backend API ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Cloudinary CDN assets ─────────────────────────────────────────────────────
# Set these in Vercel's environment variable dashboard.
# For local development, copy to .env.local and fill in the Cloudinary URLs,
# or leave unset to fall back to the local /public/assets/ copies.
NEXT_PUBLIC_LOGO_URL=
NEXT_PUBLIC_FAVICON_URL=
NEXT_PUBLIC_INSTRUCTOR_IMG_1=
NEXT_PUBLIC_INSTRUCTOR_IMG_2=
